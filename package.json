{
  "name": "stock-elements",
  "version": "0.3.0",
  "description": "Framework-agnostic Lit web components for the Stockroom family — loading bar, searchable viewport-aware select, and more. Ships ESM + TypeScript types + optional React adapters.",
  "type": "module",
  "license": "MIT",
  "author": "Federal Color <info@federalcolor.com> (https://federalcolor.com)",
  "homepage": "https://github.com/ittenom/stock-elements#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ittenom/stock-elements.git"
  },
  "bugs": {
    "url": "https://github.com/ittenom/stock-elements/issues"
  },
  "keywords": [
    "web-components",
    "lit",
    "lit-element",
    "custom-elements",
    "react",
    "select",
    "combobox",
    "dropdown",
    "loading",
    "progress",
    "stockroom",
    "design-system"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/components/loading-bar/index.js",
    "./dist/components/loading-bar/loading-bar.js",
    "./dist/components/loading-grid/index.js",
    "./dist/components/loading-grid/loading-grid.js",
    "./dist/components/select/index.js",
    "./dist/components/select/select.js",
    "./dist/chunks/*.js",
    "./src/index.ts",
    "./src/components/loading-bar/index.ts",
    "./src/components/loading-bar/loading-bar.ts",
    "./src/components/loading-grid/index.ts",
    "./src/components/loading-grid/loading-grid.ts",
    "./src/components/select/index.ts",
    "./src/components/select/select.ts"
  ],
  "files": [
    "dist",
    "THEMING.md",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loading-bar": {
      "types": "./dist/components/loading-bar/index.d.ts",
      "import": "./dist/components/loading-bar/index.js"
    },
    "./loading-bar/react": {
      "types": "./dist/components/loading-bar/react.d.ts",
      "import": "./dist/components/loading-bar/react.js"
    },
    "./loading-grid": {
      "types": "./dist/components/loading-grid/index.d.ts",
      "import": "./dist/components/loading-grid/index.js"
    },
    "./loading-grid/react": {
      "types": "./dist/components/loading-grid/react.d.ts",
      "import": "./dist/components/loading-grid/react.js"
    },
    "./select": {
      "types": "./dist/components/select/index.d.ts",
      "import": "./dist/components/select/index.js"
    },
    "./select/react": {
      "types": "./dist/components/select/react.d.ts",
      "import": "./dist/components/select/react.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "vite build --config vite.lib.config.ts",
    "build:showcase": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "lit": "^3.2.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "lit": "^3.2.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.6"
  }
}
